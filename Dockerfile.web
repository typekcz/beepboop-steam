FROM node:21-bookworm

ARG BROWSER_DEB=""
ARG BROWSER_PATH="/usr/bin/chromium"

RUN apt update && \
	if [ -n "$BROWSER_DEB" ]; then \
		curl -L -o /tmp/pkg.deb "$BROWSER_DEB" && \
		apt install -y /tmp/pkg.deb && \
		rm /tmp/pkg.deb; \
	else \
		apt install -y chromium; \
	fi

ENV PUPPETEER_SKIP_CHROMIUM_DOWNLOAD 1
ENV PUPPETEER_EXECUTABLE_PATH ${BROWSER_PATH}
COPY . /beepboop
WORKDIR /beepboop
RUN npm install
ENTRYPOINT ["npm", "start"]
